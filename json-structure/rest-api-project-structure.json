{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/microsoft-project/refs/heads/main/json-structure/rest-api-project-structure.json",
  "name": "Project",
  "description": "Project schema from Microsoft Project Online REST API",
  "type": "object",
  "properties": {
    "Id": {
      "type": "uuid",
      "description": "Unique identifier of the project"
    },
    "Name": {
      "type": "string",
      "description": "Name of the project"
    },
    "Description": {
      "type": "string",
      "description": "Description of the project"
    },
    "StartDate": {
      "type": "datetime",
      "description": "Project start date"
    },
    "FinishDate": {
      "type": "datetime",
      "description": "Project finish date"
    },
    "CreatedDate": {
      "type": "datetime",
      "description": "Date the project was created"
    },
    "ModifiedDate": {
      "type": "datetime",
      "description": "Date the project was last modified"
    },
    "IsCheckedOut": {
      "type": "boolean",
      "description": "Whether the project is currently checked out"
    },
    "CheckedOutBy": {
      "type": "string",
      "description": "User who checked out the project"
    },
    "PercentComplete": {
      "type": "int32",
      "description": "Overall completion percentage"
    },
    "ProjectType": {
      "type": "int32",
      "description": "Enterprise project type identifier"
    },
    "ProjectSiteUrl": {
      "type": "uri",
      "description": "URL to the project site"
    }
  }
}
